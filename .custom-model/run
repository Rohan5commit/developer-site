#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ENV="${MODAL_PROJECT_ENV_FILE:-$ROOT_DIR/project.env}"

if [[ -f "$PROJECT_ENV" ]]; then
  set -a
  source "$PROJECT_ENV"
  set +a
fi

# Manual workspace switch only:
# - default: primary
# - explicit: `custom-model second` or `custom-model 2nd` -> backup
if [[ "${1:-}" == "second" || "${1:-}" == "2nd" ]]; then
  export CUSTOM_MODEL_WORKSPACE="backup"
  shift
else
  export CUSTOM_MODEL_WORKSPACE="${CUSTOM_MODEL_WORKSPACE:-primary}"
fi

if [[ "$CUSTOM_MODEL_WORKSPACE" == "backup" ]]; then
  export MODAL_PROFILE="${MODAL_BACKUP_PROFILE:-default}"
else
  export MODAL_PROFILE="${MODAL_PRIMARY_PROFILE:-secondary-failover}"
fi

PYBIN="${MODAL_PYTHON_BIN:-$HOME/.local/pipx/venvs/modal/bin/python}"

exec "$PYBIN" "$ROOT_DIR/custom_model.py" "$@"
